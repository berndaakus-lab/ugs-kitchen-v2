# Copy to .env.local and fill in values

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Set to "true" to show the Coming Soon page instead of the app
# Set on Vercel: Production env → NEXT_PUBLIC_COMING_SOON=true
#                Preview/Staging → NEXT_PUBLIC_COMING_SOON=false
NEXT_PUBLIC_COMING_SOON=false
