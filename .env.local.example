# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Paystack (server-side only — never expose secret key to client)
PAYSTACK_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxx
PAYSTACK_WEBHOOK_SECRET=your-webhook-secret-hash

# Nkomo SMS (server-side only — never expose to client)
NKOMO_API_KEY=your-nkomo-api-key
NKOMO_SENDER_ID=UGsKitchen

# Owner phone number for new-order SMS alerts (Ghana format, e.g. 0244123456)
OWNER_PHONE=0244XXXXXX

# App
NEXT_PUBLIC_APP_URL=https://ugskitchen.com

# Admin page PIN (owner uses this to log into /admin)
NEXT_PUBLIC_ADMIN_PIN=1234

# Vercel Cron secret — any random string, added to Vercel env vars too
CRON_SECRET=change-this-to-a-random-string

# Social handles (optional — shown in footer)
NEXT_PUBLIC_INSTAGRAM=ugskitchen
NEXT_PUBLIC_FACEBOOK=ugskitchen
NEXT_PUBLIC_TIKTOK=ugskitchen
